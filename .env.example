# NBA Oracle v4.0 — Environment Variables

# Discord webhook for alerts (optional — alerts skipped if unset)
DISCORD_WEBHOOK_URL=

# Resend email alerts (optional)
RESEND_API_KEY=
RESEND_FROM=nba-oracle@yourdomain.com
RESEND_TO=you@yourdomain.com

# The Odds API for live Vegas lines (optional — free tier: 500 requests/month)
# Get your key at https://the-odds-api.com
ODDS_API_KEY=

# Cache and database paths (optional — defaults to ./cache and ./data)
CACHE_DIR=./cache
DB_PATH=./data/nba_oracle.db
CACHE_TTL_HOURS=1

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info
